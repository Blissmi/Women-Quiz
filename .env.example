# Example environment variables for production
# Use a secure password and never commit real secrets.

# Option A: single DATABASE_URL
# Example: postgres://blissmi_user:strongpassword@db.example.com:5432/blissmi_db
DATABASE_URL=

# Option B: individual PG_* vars
PGHOST=localhost
PGPORT=5432
PGUSER=blissmi_user
PGPASSWORD=strongpassword
PGDATABASE=blissmi_db

# When running in production behind managed Postgres, enable NODE_ENV=production
NODE_ENV=production
# Copy to .env.local and fill values
# Airtable API key and base for the helper server
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Port the helper server listens on (optional)
PORT=4000

# Frontend: base URL for the helper server (optional). If omitted, frontend will attempt http://localhost:4000
VITE_API_BASE=http://localhost:4000

# Optional Redis configuration (enable by setting REDIS_URL)
# Example: REDIS_URL=redis://:password@localhost:6379/0
REDIS_URL=
